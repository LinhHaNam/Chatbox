  "components": {
    "schemas": {
      "CreateChatSessionRequest": {
        "type": "object",
        "properties": {
          "sessionTitle": {
            "type": "string",
            "nullable": true
          },
          "defaultRudenessLevel": {
            "$ref": "#/components/schemas/RudenessLevel"
          }
        },
        "additionalProperties": false
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "RefreshTokenRequest": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "RegisterRequest": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "RudenessLevel": {
        "enum": [
          "Polite",
          "Neutral",
          "Casual",
          "Sarcastic",
          "Rude"
        ],
        "type": "string"
      },
      "SendMessageRequest": {
        "type": "object",
        "properties": {
          "sessionId": {
            "type": "string",
            "format": "uuid"
          },
          "content": {
            "type": "string",
            "nullable": true
          },
          "rudenessLevel": {
            "$ref": "#/components/schemas/RudenessLevel"
          }
        },
        "additionalProperties": false
      },
      "UpdateSessionRudenessLevelRequest": {
        "type": "object",
        "properties": {
          "rudenessLevel": {
            "$ref": "#/components/schemas/RudenessLevel"
          }
        },
        "additionalProperties": false
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "description": "JWT Authorization header using the Bearer scheme. Example: \"Authorization: Bearer {token}\"",
        "scheme": "Bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
    {
      "Bearer": [ ]
    }
  ]
}